<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Night override: switch status/nav bar icon tint to light (white icons
        on dark background). Dynamic Colors still applies on top of this.
    -->
    <style name="Base.Theme.HyperMTZ" parent="Theme.Material3.DynamicColors.DayNight">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorOnPrimaryContainer">@color/brand_on_primary_container</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Dark theme: icons must be light. -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
