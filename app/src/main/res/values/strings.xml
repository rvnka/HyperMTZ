    <!-- Accessibility service -->
    <string name="accessibility_service_description">Dynamically registers a broadcast receiver (priority 1000) via accessibility service, to receive MIUI theme-check and screen-off broadcasts first. Runs in a separate process with a foreground service to resist MIUI background kill. Note: CHECK_TIME_UP may be a regular broadcast on some ROMs — interception is attempted but cannot be guaranteed to block delivery in all cases.</string>

    <!-- About dialog -->
    <string name="about_title">HyperMTZ</string>
    <string name="about_author">by Rinn (@rvnka)</string>
    <string name="about_version">Version %1$s</string>
    <string name="about_description">Patches MIUI/HyperOS theme authorization using Accessibility Service. Uses ThemeStore ZWS path trick (no Shizuku needed). Shizuku provides privileged fallback for file copy only.</string>

